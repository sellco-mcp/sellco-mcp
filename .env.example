# ─────────────────────────────────────────────────────────────
#  Sellco Amazon MCP Server — Environment Variables
#  Railway sets PORT automatically — do not change it
#  SELLCO_API_URL — do not change
# ─────────────────────────────────────────────────────────────

PORT=3000
SELLCO_API_URL=https://api.sellco.ai
SELLCO_API_KEY=your_sellco_api_key_here
NODE_ENV=production
